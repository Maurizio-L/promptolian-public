{
  "manifest_version": 2,
  "name": "Promptolian — Token Compressor",
  "version": "1.0.0",
  "description": "Automatically compress your AI prompts to save 40–65% of tokens. Works on Claude, ChatGPT, Gemini, Copilot.",
  "permissions": [
    "activeTab",
    "storage",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Promptolian",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "promptly@promptly.so",
      "strict_min_version": "109.0"
    }
  }
}
